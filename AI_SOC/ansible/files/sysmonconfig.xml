<Sysmon schemaversion="4.90">
  <HashAlgorithms>md5,sha256</HashAlgorithms>
  <CheckRevocation/>
  <EventFiltering>
    <!-- Event ID 1: Process Creation -->
    <RuleGroup name="" groupRelation="or">
      <ProcessCreate onmatch="exclude">
        <IntegrityLevel condition="is">System</IntegrityLevel>
      </ProcessCreate>
    </RuleGroup>

    <!-- Event ID 3: Network Connection -->
    <RuleGroup name="" groupRelation="or">
      <NetworkConnect onmatch="include">
        <DestinationPort condition="is">80</DestinationPort>
        <DestinationPort condition="is">443</DestinationPort>
      </NetworkConnect>
    </RuleGroup>

    <!-- Event ID 22: DNS Query -->
    <!-- Log Shadow AI domain lookups to detect bypass attempts -->
    <RuleGroup name="ShadowAI" groupRelation="or">
      <DnsQuery onmatch="include">
        <QueryName condition="contains">openai.com</QueryName>
        <QueryName condition="contains">anthropic.com</QueryName>
        <QueryName condition="contains">claude.ai</QueryName>
        <QueryName condition="contains">perplexity.ai</QueryName>
        <QueryName condition="contains">huggingface.co</QueryName>
        <QueryName condition="contains">gemini.google.com</QueryName>
      </DnsQuery>
    </RuleGroup>
  </EventFiltering>
</Sysmon>
